---

---
<section id="skills" class="py-32 px-6 bg-neutral-900/50">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-4xl font-bold mb-4">Stack tecnológico</h2>
            <p class="text-neutral-400">Tecnologías con las que trabajo día a día</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <!-- Frontend -->
            <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
                <div class="w-12 h-12 bg-emerald-400/10 rounded-lg flex items-center justify-center mb-4">
                    <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold mb-3">Frontend</h3>
                <ul class="space-y-2 text-neutral-400 text-sm">
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                        React / Next.js
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                        TypeScript
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                        Tailwind CSS
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-emerald-400 rounded-full"></div>
                        Redux / Zustand
                    </li>
                </ul>
            </div>

            <!-- Backend -->
            <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
                <div class="w-12 h-12 bg-cyan-400/10 rounded-lg flex items-center justify-center mb-4">
                    <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold mb-3">Backend</h3>
                <ul class="space-y-2 text-neutral-400 text-sm">
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div>
                        Node.js / Express
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div>
                        MongoDB / PostgreSQL
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div>
                        REST APIs / GraphQL
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-cyan-400 rounded-full"></div>
                        JWT / OAuth
                    </li>
                </ul>
            </div>

            <!-- Tools -->
            <div class="bg-neutral-900 rounded-xl p-6 border border-neutral-800">
                <div class="w-12 h-12 bg-purple-400/10 rounded-lg flex items-center justify-center mb-4">
                    <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <h3 class="text-lg font-semibold mb-3">Herramientas</h3>
                <ul class="space-y-2 text-neutral-400 text-sm">
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-purple-400 rounded-full"></div>
                        Git / GitHub
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-purple-400 rounded-full"></div>
                        Docker
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-purple-400 rounded-full"></div>
                        AWS / Vercel
                    </li>
                    <li class="flex items-center gap-2">
                        <div class="w-1.5 h-1.5 bg-purple-400 rounded-full"></div>
                        Jest / Cypress
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>